{
  "name": "panaderia",
  "version": "0.1.0",
  "private": true,
  "devDependencies": {
    "@pushforge/builder": "^2.0.1",
    "@ramiidv/arca-facturacion": "^2.0.0",
    "env-cmd": "^10.1.0",
    "supabase": "^2.76.0"
  },
  "dependencies": {
    "@sentry/react": "^10.41.0",
    "@supabase/supabase-js": "^2.98.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "html2canvas": "^1.4.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:staging": "env-cmd -f .env.staging react-scripts build",
    "import-recetas": "env-cmd -f .env.development.local node scripts/import-recetas.js",
    "import-recetas:clear": "env-cmd -f .env.development.local node scripts/import-recetas.js --clear",
    "import-recetas:upsert": "env-cmd -f .env.development.local node scripts/import-recetas.js --upsert",
    "copy:prod-to-dev": "node scripts/copy-prod-to-dev.js",
    "supabase:link": "supabase link --project-ref xdiggsdjmmylkvephyod",
    "supabase:link:prod": "supabase link --project-ref clgxrxlccjjqxzvapfav",
    "db:push": "supabase db push --yes",
    "db:push:dev": "supabase link --project-ref xdiggsdjmmylkvephyod && supabase db push --yes --include-all",
    "bootstrap:roles": "env-cmd -f .env.development.local node scripts/bootstrap-user-roles.js",
    "db:push:prod": "supabase link --project-ref clgxrxlccjjqxzvapfav && supabase db push --yes --include-all",
    "push:diagnose:prod": "node scripts/push-diagnose-prod.js",
    "push:test:prod": "node scripts/push-test-prod.js",
    "push:analyze:prod": "node scripts/push-analyze-prod.js",
    "push:magic-link": "node scripts/push-magic-link.js",
    "push:icons": "bash scripts/generate-notification-icons.sh",
    "push:vapid:set": "node scripts/push-set-vapid-secrets.js",
    "push:deploy": "supabase link --project-ref clgxrxlccjjqxzvapfav && supabase functions deploy send-push notify-event",
    "functions:deploy:afip": "npm run supabase:link && supabase functions deploy registrar-en-afip",
    "secrets:set:afip-mock": "npm run supabase:link && supabase secrets set AFIP_ALLOW_MOCK=true",
    "afip:setup": "./scripts/afip-setup-secrets.sh",
    "afip:setup:local": "./scripts/afip-setup-from-local.sh",
    "afip:setup:prod": "AFIP_PRODUCTION=true AFIP_SETUP_PROD=1 ./scripts/afip-setup-from-local.sh",
    "afip:listar-pv": "NODE_OPTIONS='--tls-cipher-list=DEFAULT@SECLEVEL=1' node scripts/afip-listar-puntos-venta.mjs",
    "seed:paginacion": "env-cmd -f .env.development.local node scripts/seed-ventas-paginacion.js",
    "test": "react-scripts test",
    "check:bundle": "npm run build && node scripts/check-main-bundle-size.js",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
