# Desarrollo - copiá a .env.development.local (gitignored)
# Se usa con: npm start
REACT_APP_SUPABASE_URL=https://tu-proyecto-dev.supabase.co
REACT_APP_SUPABASE_ANON_KEY=tu-anon-key-dev
REACT_APP_ENV=development

# AFIP mock en dev: en Supabase (proyecto dev) ejecutá npm run secrets:set:afip-mock
# y npm run functions:deploy:afip. Sin AFIP_PRODUCTION=true en ese proyecto.
