# Producción - copiá a .env.production.local (gitignored)
# Se usa con: npm run build
REACT_APP_SUPABASE_URL=https://tu-proyecto.supabase.co
REACT_APP_SUPABASE_ANON_KEY=tu-anon-key
REACT_APP_ENV=production

# Web Push (obligatorio para notificaciones en prod)
# Generar par: npx @pushforge/builder vapid — ver docs/PUSH_VAPID_Y_DEPLOY.md
# REACT_APP_VAPID_PUBLIC_KEY=BE...

# Opcional: Sentry para logs de errores
# REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
