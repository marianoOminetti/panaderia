# Supabase - copiá a .env.local o al archivo del ambiente que uses
# Los archivos .env.development, .env.staging, .env.production definen cada ambiente
REACT_APP_SUPABASE_URL=https://tu-proyecto.supabase.co
REACT_APP_SUPABASE_ANON_KEY=tu-anon-key

# Opcional: identificar el ambiente en la app
# REACT_APP_ENV=development|staging|production

# Notificaciones push (Web Push): clave pública VAPID (obligatorio si usás push)
# Generar par: npx web-push generate-vapid-keys
# REACT_APP_VAPID_PUBLIC_KEY=BH... (la clave pública, base64url)

# Opcional: Sentry para logs de errores en producción
# Creá un proyecto en sentry.io y pegá el DSN
# REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
